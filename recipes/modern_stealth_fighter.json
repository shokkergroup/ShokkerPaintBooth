      "intensity": "100",
      "colorMode": "quick",
      "pickerColor": "#333333",
      "pickerTolerance": 35,
      "patternIntensity": "95",
      "scale": 0.85
    },
    {
      "name": "Warning Chevrons",
      "color": "yellow",
      "base": "semi_gloss",
      "pattern": "racing_stripe",
      "intensity": "100",
      "colorMode": "quick",
      "pickerColor": "#ffcc00",
