{
  "name": "Japanese Bosozoku",
  "description": "Wild pearl candy paint with heavy graphics, kanji inspired panels, and deep metallic flake. Pays tribute to 80s-90s Japanese biker/street styling with absolutely zero restraint.",
  "author": "Shokker Paint Booth",
  "version": "6.2.0",
  "compatible_with": "any JDM chassis, especially kyusha / ita shakotan-style bodies",
  "notes": "The pearl candy base is HEAVY — bring scale down on metallic flake if the final render feels overwhelming. This recipe leans into pink/purple, swap Body baseColor to #2a5ec6 for classic 'police-blue' bosozoku.",
  "zones": [
    {
      "name": "Candy Pearl Body",
      "color": "everything",
      "base": "candy_apple",
      "pattern": "none",
      "intensity": "100",
      "colorMode": "special",
      "baseColor": "#c41a6b",
      "baseColorMode": "solid",
      "baseStrength": 1,
      "baseSpecStrength": 1
    },
    {
      "name": "Pearl Flake Wash",
