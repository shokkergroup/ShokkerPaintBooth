    {
      "name": "Body Color",
      "color": "everything",
      "base": "gloss",
      "pattern": "none",
      "intensity": "100",
      "colorMode": "special",
      "baseColor": "#18c44a",
      "baseColorMode": "solid",
      "baseStrength": 1,
      "baseSpecStrength": 1
    },
    {
      "name": "Mud Spatter Upper",
      "color": "remaining",
      "base": "rally_mud",
      "pattern": "none",
      "intensity": "70",
      "colorMode": "special",
      "baseColor": "#5a3a1c",
      "baseColorMode": "solid",
      "baseStrength": 0.7,
      "baseSpecStrength": 0.5
    },
    {
      "name": "Heavy Mud Lower",
      "color": "dark",
      "base": "rally_mud",
      "pattern": "none",
      "intensity": "100",
      "colorMode": "quick",
      "pickerColor": "#3a2714",
      "pickerTolerance": 40,
      "baseColor": "#3a2714",
      "baseColorMode": "solid",
      "baseStrength": 1,
      "baseSpecStrength": 0.3
    },
    {
