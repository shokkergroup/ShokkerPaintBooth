{
  "version": "6.2.0",
  "description": "Driver suit template metadata for SPB",
  "templates": [
    {
      "id": "iracing_default_suit",
      "name": "iRacing Default Suit",
      "canvas_size": [1024, 1024],
      "uv_zones": ["chest", "back", "left_arm", "right_arm", "left_leg", "right_leg", "collar", "belt", "left_shoulder", "right_shoulder"],
      "iracing_folder": "suits",
      "filename_convention": "suit_<iracing_id>.tga",
      "spec_filename": "suit_spec_<iracing_id>.tga",
      "default_dpi": 96,
      "supports_spec_map": true,
      "alpha_supported": false,
      "notes": "Standard iRacing one-piece driver suit template. 10 UV zones. Spec map controls fabric sheen — keep matte (low metallic, high roughness) for realistic Nomex."
    },
    {
      "id": "iracing_hd_suit",
      "name": "iRacing HD Suit (2048)",
      "canvas_size": [2048, 2048],
      "uv_zones": ["chest", "back", "left_arm", "right_arm", "left_leg", "right_leg", "collar", "belt", "left_shoulder", "right_shoulder", "left_cuff", "right_cuff", "left_knee_panel", "right_knee_panel"],
      "iracing_folder": "suits",
      "filename_convention": "suit_<iracing_id>.tga",
      "spec_filename": "suit_spec_<iracing_id>.tga",
      "default_dpi": 192,
      "supports_spec_map": true,
      "alpha_supported": false,
      "notes": "Higher-resolution suit template. Adds cuffs and knee panels for tactical detail and patch placement."
    },
    {
      "id": "vintage_two_piece",
      "name": "Vintage Two-Piece Suit",
      "canvas_size": [1024, 1024],
      "uv_zones": ["jacket_chest", "jacket_back", "jacket_arms", "jacket_collar", "pants_front", "pants_back", "belt"],
      "iracing_folder": "suits",
      "filename_convention": "suit_<iracing_id>.tga",
      "spec_filename": "suit_spec_<iracing_id>.tga",
      "default_dpi": 96,
      "supports_spec_map": true,
      "alpha_supported": false,
      "notes": "Vintage two-piece jacket-and-pants layout for historic series. Smaller graphic palette is common for period accuracy."
    },
    {
      "id": "spb_native_suit_2k",
      "name": "SPB Native Suit 2K",
      "canvas_size": [2048, 2048],
      "uv_zones": ["chest_panel", "back_panel", "shoulder_yoke", "left_arm", "right_arm", "left_leg", "right_leg", "collar", "belt", "name_strip", "country_strip", "logo_field_chest", "logo_field_back"],
      "iracing_folder": "suits",
      "filename_convention": "spb_suit_<slug>.tga",
      "spec_filename": "spb_suit_<slug>_spec.tga",
      "default_dpi": 192,
      "supports_spec_map": true,
      "alpha_supported": true,
      "notes": "SPB-native suit template. Adds dedicated logo_field zones for sponsor placement and explicit name/country strips for driver identity."
    }
  ],
  "default_template": "iracing_default_suit",
  "uv_zone_descriptions": {
    "chest": "Front torso, primary sponsor zone",
    "back": "Rear torso, primary identity zone (driver name, big sponsor)",
    "left_arm": "Left sleeve, sponsor patches",
    "right_arm": "Right sleeve, sponsor patches",
    "left_leg": "Left thigh panel",
    "right_leg": "Right thigh panel",
    "collar": "Neck collar band",
    "belt": "Waist belt zone",
    "left_shoulder": "Left shoulder yoke, often patch territory",
    "right_shoulder": "Right shoulder yoke, often patch territory",
    "left_cuff": "Left wrist cuff",
    "right_cuff": "Right wrist cuff",
    "left_knee_panel": "Left knee patch zone",
    "right_knee_panel": "Right knee patch zone",
    "jacket_chest": "Vintage two-piece jacket front",
    "jacket_back": "Vintage two-piece jacket back",
    "jacket_arms": "Vintage two-piece jacket sleeves",
    "jacket_collar": "Vintage jacket collar",
    "pants_front": "Vintage pants front",
    "pants_back": "Vintage pants back",
    "chest_panel": "SPB native chest panel",
    "back_panel": "SPB native back panel",
    "shoulder_yoke": "SPB native combined shoulder yoke",
    "name_strip": "SPB native driver-name strip",
    "country_strip": "SPB native country flag strip",
    "logo_field_chest": "SPB native chest sponsor field",
    "logo_field_back": "SPB native back sponsor field"
  }
