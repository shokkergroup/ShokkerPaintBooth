{
  "id": "chevy_silverado_2019",
  "name": "Chevy Silverado 2019",
  "category": "NASCAR Truck",
  "canvas_size": [2048, 2048],
  "color_space": "sRGB",
  "alpha_required": true,
  "iracing_folder": "trucks/silverado2019",
  "schema_version": "1.0.0",
  "layer_tree": [
    {
      "name": "Wire",
      "type": "raster",
      "purpose": "Wireframe overlay for placement reference. Hide before TGA export.",
      "default_visibility": true,
      "export_visibility": false
    },
    {
      "name": "Mask",
      "type": "mask",
      "purpose": "Defines paintable region. Used by SPB to constrain paint to body panels.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Paintable Area",
      "type": "group",
      "purpose": "All user-editable paint and sponsor layers live inside.",
      "children": [
        "Car_Paint",
        "Numbers",
        "Sponsors",
        "Tape",
        "Color Change Logos"
      ]
    },
    {
      "name": "Car_Paint",
      "type": "raster",
      "purpose": "Base paint layer. SPB writes generated paint output here.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Numbers",
      "type": "smart_object",
      "purpose": "Driver number panels. Three locations: doors (both sides) + roof.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Sponsors",
      "type": "group",
      "purpose": "All sponsor logos. Subgroups for primary, associate, contingency.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Tape",
      "type": "raster",
      "purpose": "Decorative tape stripe overlays.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Pitbox Colors",
      "type": "raster",
      "purpose": "Sets pit stall signage color in iRacing UI. Not visible on car.",
      "default_visibility": false,
      "export_visibility": true
    },
    {
      "name": "Color Change Logos",
      "type": "raster",
      "purpose": "Manufacturer logos that recolor based on team palette.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Windshield Banner",
      "type": "raster",
      "purpose": "Top-of-windshield driver name strip.",
      "default_visibility": true,
      "export_visibility": true
    },
    {
      "name": "Turn Off Before Exporting TGA",
      "type": "group",
      "purpose": "Reference-only layers. Toggle off before final export.",
      "children": ["Wire", "Guides", "Notes"],
      "default_visibility": true,
      "export_visibility": false
    }
  ],
  "uv_safe_areas": [
    {
      "name": "left_door_panel",
      "bbox_uv": [0.10, 0.40, 0.30, 0.62],
      "use": "primary sponsor / driver number"
    },
    {
      "name": "right_door_panel",
      "bbox_uv": [0.55, 0.40, 0.75, 0.62],
      "use": "primary sponsor / driver number (mirror)"
    },
    {
      "name": "hood",
      "bbox_uv": [0.30, 0.05, 0.60, 0.32],
      "use": "primary sponsor"
    },
    {
      "name": "roof",
      "bbox_uv": [0.32, 0.62, 0.55, 0.80],
      "use": "spotter number / large secondary sponsor"
    },
    {
      "name": "front_fender_left",
      "bbox_uv": [0.05, 0.32, 0.18, 0.42],
      "use": "associate sponsor"
    },
    {
      "name": "front_fender_right",
      "bbox_uv": [0.62, 0.32, 0.75, 0.42],
      "use": "associate sponsor"
    },
    {
      "name": "rear_quarter_left",
      "bbox_uv": [0.05, 0.62, 0.18, 0.78],
      "use": "contingency stack"
    },
    {
      "name": "rear_quarter_right",
      "bbox_uv": [0.62, 0.62, 0.75, 0.78],
      "use": "contingency stack"
    },
    {
      "name": "tailgate",
      "bbox_uv": [0.78, 0.40, 0.95, 0.62],
      "use": "secondary sponsor / class branding"
    }
  ],
  "number_panels": [
    {"id": "door_left", "bbox_uv": [0.16, 0.45, 0.26, 0.58]},
    {"id": "door_right", "bbox_uv": [0.59, 0.45, 0.69, 0.58]},
    {"id": "roof", "bbox_uv": [0.36, 0.66, 0.50, 0.76]}
  ],
  "windshield_banner": {
    "bbox_uv": [0.30, 0.86, 0.60, 0.92],
    "max_chars": 18,
    "default_height_px": 96
  },
  "recommended_zones": [
    {
      "id": "hood_zone",
      "label": "Hood",
      "default_finish": "metallic_standard",
      "default_color": "#0B0F1F"
    },
    {
      "id": "doors_zone",
      "label": "Doors",
      "default_finish": "candy_special",
      "default_color": "#C20000"
    },
    {
      "id": "roof_zone",
      "label": "Roof",
      "default_finish": "matte_basic",
      "default_color": "#0A0A0A"
    },
    {
      "id": "fenders_zone",
      "label": "Fenders",
      "default_finish": "metallic_flake",
      "default_color": "#FFB400"
    },
    {
      "id": "rear_quarter_zone",
      "label": "Rear Quarters",
      "default_finish": "carbon_composite",
      "default_color": "#1A1A1A"
    }
  ],
  "warnings": [
    "Wire layer must be hidden before TGA export or it will bleed into the in-game livery.",
    "Numbers layer is a smart object; double-click to swap car number across all three positions at once.",
    "Pitbox Colors uses a 4-pixel sample swatch; only the center pixel is read by iRacing."
  ],
  "tips": [
    "Use the Mask layer as a clipping mask when painting custom shapes outside SPB.",
    "Mirror left-side sponsor placement to the right side for symmetry; SPB has a one-click clone tool.",
    "Reserve at least 256 px of padding around door numbers to keep them legible at TV distance."
  ]
}
