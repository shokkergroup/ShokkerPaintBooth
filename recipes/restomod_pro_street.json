    {
      "name": "Deep Gloss Body",
      "color": "everything",
      "base": "gloss",
      "pattern": "none",
      "intensity": "100",
      "colorMode": "special",
      "baseColor": "#2a0d40",
      "baseColorMode": "solid",
      "baseStrength": 1,
      "baseSpecStrength": 1
    },
    {
      "name": "Subtle Metalflake",
      "color": "remaining",
      "base": "pearl",
      "pattern": "none",
      "intensity": "45",
      "colorMode": "special",
      "baseColor": "#6b3d8a",
      "baseColorMode": "solid",
      "baseStrength": 0.4,
      "baseSpecStrength": 1
    },
    {
