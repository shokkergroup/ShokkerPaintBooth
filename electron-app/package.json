{
  "name": "shokker-paint-booth-v6",
  "version": "6.2.0",
  "description": "Shokker Paint Booth V6 — iRacing Spec Map Tool",
  "main": "main.js",
  "author": "Shokker Group",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "copy-server": "node copy-server-assets.js",
    "sync-runtime": "node ../scripts/sync-runtime-copies.js --write",
    "check-runtime-sync": "node ../scripts/sync-runtime-copies.js --check",
    "prebuild": "npm run copy-server",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.shokker.paintbooth.v6",
    "productName": "Shokker Paint Booth V6",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "artifactName": "ShokkerPaintBoothV6-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "Shokker Paint Booth V6"
    },
    "files": [
      "main.js",
      "preload.js",
      "license.html",
      "license-preload.js"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "ShokkerGroup",
      "repo": "ShokkerPaintBooth"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
