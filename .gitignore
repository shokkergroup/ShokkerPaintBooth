# ============================================================================
# Shokker Paint Booth — .gitignore
# ----------------------------------------------------------------------------
# Keep this list comprehensive. Pairs of the same pattern in different
# sections are intentional for grouping/clarity.
# ============================================================================

# ----- Sandbox / agent write-probe debris ------------------------------------
# Codex (and similar sandboxed agents under PowerShell ConstrainedLanguage
# mode) drop 4-byte "blat" sentinel files at the working directory root to
# probe write permissions, then fail to clean them up. Match the canonical
# 8-character lowercase-alphanumeric (with optional underscore) pattern at
# repo root only — this won't shadow legit subfolder files. Kill on sight.
/[a-z0-9_][a-z0-9_][a-z0-9_][a-z0-9_][a-z0-9_][a-z0-9_][a-z0-9_][a-z0-9_]
/.codex-tmp/
/.pytest-tmp/

# ----- Python build artifacts ------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/
server.build/
server.dist/
server.onefile-build/
_nuitka_test/
_pybuild_work/
_pybuild_work_ag/

# ----- Binaries --------------------------------------------------------------
*.exe
*.pdb
*.dll
*.so
*.dylib

# ----- Logs ------------------------------------------------------------------
*.log
logs/
*_log.txt
server_err.txt
server_log.txt
server_log.txt.*
server_out.txt
build_log*.txt
build_output.txt
_server_stdout.txt
_server_stderr.txt
_server_err.txt
npm_build_log.txt
rebuild_log.txt

# ----- Electron / Node -------------------------------------------------------
node_modules/
electron-app/dist/
electron-app/node_modules/
electron-app/_build_*.txt
electron-app/_build_*.log
electron-app/out/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----- Electron-builder outputs ---------------------------------------------
dist_electron/
release/
out/
app-builds/

