{
  "$schema": "https://json.schemastore.org/prettierrc",
  "printWidth": 120,
  "tabWidth": 4,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "auto",
  "singleAttributePerLine": false,
  "htmlWhitespaceSensitivity": "css",
  "proseWrap": "preserve",
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", ".prettierrc"],
      "options": {
        "tabWidth": 2,
        "singleQuote": false,
        "trailingComma": "none"
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "tabWidth": 2,
        "singleQuote": false
      }
    },
    {
      "files": ["*.md"],
      "options": {
        "tabWidth": 4,
        "proseWrap": "preserve",
        "embeddedLanguageFormatting": "off"
      }
    },
    {
      "files": ["*.html"],
      "options": {
        "tabWidth": 4,
        "printWidth": 140
      }
    },
    {
      "files": ["*.css", "*.scss"],
      "options": {
        "tabWidth": 4,
        "singleQuote": false
      }
    }
  ]
}
