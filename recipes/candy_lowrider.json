{
  "name": "Candy Lowrider",
  "description": "Full-on candy paint lowrider with heavy metal flake, gold leaf pinstripes, chrome everything, and pearl pattern overlays. A rolling sculpture built for slow cruising and cameras.",
  "author": "Shokker Paint Booth",
  "version": "6.2.0",
  "compatible_with": "impala, cadillac, cutlass, monte_carlo, any G-body classic",
  "notes": "Lowrider style LIVES in the paint depth — don't skimp on Pearl Overlay strength. Candy body responds strongly to lighting; adjust baseColor to match your crew/theme. Chrome should cover bumpers, trim, and mirrors.",
  "zones": [
    {
      "name": "Candy Apple Body",
      "color": "everything",
      "base": "candy_apple",
      "pattern": "none",
      "intensity": "100",
      "colorMode": "special",
      "baseColor": "#a8002a",
      "baseColorMode": "solid",
      "baseStrength": 1,
      "baseSpecStrength": 1
    },
    {
      "name": "Heavy Pearl Flake",
      "color": "remaining",
      "base": "pearl",
      "pattern": "none",
      "intensity": "85",
      "colorMode": "special",
      "baseColor": "#ffd8c4",
      "baseColorMode": "solid",
      "baseStrength": 0.8,
      "baseSpecStrength": 1
    },
    {
      "name": "Full Chrome Trim",
      "color": "gray",
