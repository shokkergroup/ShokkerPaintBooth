    {
      "name": "Paintable Area",
      "type": "group",
      "purpose": "User-editable paint and decals.",
      "children": ["Car_Paint", "Numbers", "Sponsors", "Tape", "Color Change Logos"]
    },
    {"name": "Car_Paint", "type": "raster", "purpose": "SPB-generated paint output.", "default_visibility": true, "export_visibility": true},
    {"name": "Numbers", "type": "smart_object", "purpose": "Driver number panels.", "default_visibility": true, "export_visibility": true},
    {"name": "Sponsors", "type": "group", "purpose": "Sponsor logos with primary/associate/contingency subgroups.", "default_visibility": true, "export_visibility": true},
    {"name": "Tape", "type": "raster", "purpose": "Tape stripe overlays.", "default_visibility": true, "export_visibility": true},
    {"name": "Pitbox Colors", "type": "raster", "purpose": "Pit stall signage color.", "default_visibility": false, "export_visibility": true},
