# ----- Benchmarks (keep code, ignore results) -------------------------------
benchmark_results/
bench_*.json
.pytest-tmp/
tests/_runtime_harness/mkdtemp/*
!tests/_runtime_harness/mkdtemp/.gitkeep
tests/_runtime_harness/temp_files/*
!tests/_runtime_harness/temp_files/.gitkeep
tests/_runtime_harness/tmp_path/no_override/*
!tests/_runtime_harness/tmp_path/no_override/.gitkeep
tests/_runtime_harness/tmp_path/with_override/*
!tests/_runtime_harness/tmp_path/with_override/.gitkeep
!tests/test_regression_high_detail_specials.py
!tests/test_regression_runtime_mirror_coverage.py
!tests/test_regression_dev_qol_tools.py
!scripts/audit_spec_pattern_quality.py
!scripts/audit_pattern_quality.py
scripts/.runtime-sync.lock
